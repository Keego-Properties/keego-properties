Options -MultiViews
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files and directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Dynamic detail pages: serve the static shell; the client reads the real id from the URL.
  RewriteRule ^property/.+ /property/__static__/ [L]
  RewriteRule ^blog/.+ /blog/__static__/ [L]
  RewriteRule ^blogs/.+ /blogs/__static__/ [L]
  RewriteRule ^community/.+ /community/__static__/ [L]
  RewriteRule ^developers/.+ /developers/__static__/ [L]
  RewriteRule ^news/.+ /news/__static__/ [L]
  RewriteRule ^services/.+ /services/__static__/ [L]

  # Prefer trailing slashes (matches Next.js export).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+[^/])$ /$1/ [R=301,L]
</IfModule>

<IfModule mod_mime.c>
  AddType image/png .png
  AddType image/jpeg .jpg .jpeg
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType image/x-icon .ico
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
